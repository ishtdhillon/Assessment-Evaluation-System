# ─── DATABASE (Supabase PostgreSQL) ──────────────────────────
DB_HOST=db.xxxxxxxxxx.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_supabase_db_password
DB_NAME=postgres

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=make_this_very_long_random_string_32chars_min
JWT_EXPIRES_IN=8h

# ─── EMAIL OTP (Gmail SMTP - easiest for beginners) ──────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
FROM_EMAIL=your_gmail@gmail.com

# ─── SERVER ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
FRONTEND_URL=*
